---
// MoFA — Your Personal Media Empire
// AAA-grade cinematic scroll experience. 13+ composited layers.
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MoFA</title>
  <link rel="icon" type="image/png" href="/favicon-32x32.png" />
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@200;300;500;700;900&family=Noto+Sans+SC:wght@300;400;700;900&display=swap" rel="stylesheet" />
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&display=swap');
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    :root{--blue:#0044cc;--cyan:#0066aa;--purple:#330099;--red:#cc0000;--orange:#cc4400;--gold:#cc8800;--magenta:#990033;--teal:#006655}
    html{overflow-x:hidden;scroll-behavior:smooth}
    body{font-family:'Outfit','Noto Sans SC',system-ui,sans-serif;background:#030303;color:#fff;overflow-x:hidden;cursor:none;font-feature-settings:'ss01','ss02';-webkit-font-smoothing:antialiased}
    @media(pointer:coarse){body{cursor:auto}}

    /* L13: Custom cursor */
    #cursor{position:fixed;width:28px;height:28px;border-radius:50%;border:1.5px solid rgba(239,68,68,.5);pointer-events:none;z-index:10013;transform:translate(-50%,-50%);mix-blend-mode:difference;transition:width .2s,height .2s}
    #cursor.hover{width:50px;height:50px;border-color:rgba(255,255,255,.6)}
    #cur-dot{position:fixed;width:5px;height:5px;border-radius:50%;background:var(--red);pointer-events:none;z-index:10014;transform:translate(-50%,-50%)}
    @media(pointer:coarse){#cursor,#cur-dot{display:none}}

    /* Video backgrounds */
    .vid-bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0}
    .vid-bg-fixed{position:fixed;inset:0;width:100%;height:100%;object-fit:cover;z-index:-1;opacity:.08}
    #act-choice .vid-bg{opacity:.2;filter:saturate(.7) contrast(1.15)}
    #act-blue .vid-bg{opacity:0;transition:opacity 1.4s;filter:saturate(1.3) hue-rotate(-10deg)}
    #act-blue.in .vid-bg{opacity:.7}
    #act-shatter .vid-bg{opacity:0;transition:opacity 1s;filter:saturate(1.5) contrast(1.3)}
    #act-shatter.in-view .vid-bg{opacity:.8}
    #act-red .vid-bg{opacity:0;transition:opacity 1.4s;filter:saturate(1.4) contrast(1.1)}
    #act-red.in .vid-bg{opacity:.7}
    #act-empire .vid-bg{opacity:0;transition:opacity 1.4s;filter:saturate(1.2) brightness(.6)}
    #act-empire.in .vid-bg{opacity:.4}

    /* L0: Mesh gradient blobs */
    .mesh-bg{position:fixed;inset:0;z-index:0;overflow:hidden}
    .blob{position:absolute;border-radius:50%;filter:blur(120px);opacity:.12;animation:blobFloat 20s ease-in-out infinite}
    .blob-1{width:600px;height:600px;background:var(--blue);top:-10%;left:-10%;animation-delay:0s}
    .blob-2{width:500px;height:500px;background:var(--purple);top:30%;right:-8%;animation-delay:-5s;animation-duration:25s}
    .blob-3{width:700px;height:700px;background:var(--cyan);bottom:-15%;left:30%;animation-delay:-10s;animation-duration:30s}
    .blob-4{width:400px;height:400px;background:var(--magenta);top:60%;left:10%;animation-delay:-15s;animation-duration:22s}
    .blob-5{width:550px;height:550px;background:var(--teal);top:10%;right:20%;animation-delay:-8s;animation-duration:28s}
    @keyframes blobFloat{0%,100%{transform:translate(0,0) scale(1) rotate(0deg)}25%{transform:translate(80px,-60px) scale(1.15) rotate(5deg)}50%{transform:translate(-40px,80px) scale(.85) rotate(-3deg)}75%{transform:translate(60px,40px) scale(1.08) rotate(2deg)}}

    /* L1: Three.js particles */
    #three-bg{position:fixed;inset:0;z-index:1}

    /* L2: Matrix rain */
    #matrix-canvas{position:fixed;inset:0;z-index:2;pointer-events:none;opacity:.06}

    /* L3: Aurora */
    #aurora-canvas{position:fixed;inset:0;z-index:3;pointer-events:none;opacity:.15;mix-blend-mode:screen}

    /* L4: Floating rings */
    .rings-layer{position:fixed;inset:0;z-index:4;pointer-events:none;overflow:hidden}
    .float-ring{position:absolute;border-radius:50%;border:1px solid;opacity:.06;animation:ringDrift linear infinite}
    .fr1{width:300px;height:300px;border-color:var(--cyan);top:15%;left:5%;animation-duration:40s}
    .fr2{width:180px;height:180px;border-color:var(--purple);top:60%;right:10%;animation-duration:35s;animation-direction:reverse}
    .fr3{width:450px;height:450px;border-color:var(--magenta);bottom:10%;left:40%;animation-duration:50s}
    .fr4{width:120px;height:120px;border-color:var(--gold);top:30%;right:30%;animation-duration:28s;animation-direction:reverse}
    .fr5{width:250px;height:250px;border-color:var(--teal);top:70%;left:15%;animation-duration:38s}
    .fr6{width:350px;height:350px;border-color:var(--blue);top:5%;right:5%;animation-duration:45s;animation-direction:reverse}
    @keyframes ringDrift{0%{transform:translate(0,0) rotate(0deg) scale(1)}20%{transform:translate(40px,-30px) rotate(72deg) scale(1.05)}40%{transform:translate(-20px,50px) rotate(144deg) scale(.95)}60%{transform:translate(50px,20px) rotate(216deg) scale(1.08)}80%{transform:translate(-30px,-40px) rotate(288deg) scale(.97)}100%{transform:translate(0,0) rotate(360deg) scale(1)}}

    /* L5: Bokeh — removed */

    /* L6: Light leaks */
    .light-leaks{position:fixed;inset:0;z-index:6;pointer-events:none;overflow:hidden;mix-blend-mode:screen;opacity:.07}
    .leak{position:absolute;border-radius:50%;filter:blur(80px)}
    .leak-1{width:400px;height:200px;background:linear-gradient(90deg,var(--red),var(--orange),var(--gold));top:20%;left:-100px;animation:leakSlide 12s ease-in-out infinite}
    .leak-2{width:300px;height:150px;background:linear-gradient(90deg,var(--cyan),var(--blue),var(--purple));bottom:30%;right:-80px;animation:leakSlide 15s ease-in-out infinite reverse}
    .leak-3{width:250px;height:250px;background:linear-gradient(135deg,var(--magenta),transparent);top:50%;left:50%;animation:leakPulse 8s ease-in-out infinite}
    @keyframes leakSlide{0%,100%{transform:translateX(0)}50%{transform:translateX(200px)}}
    @keyframes leakPulse{0%,100%{opacity:.5;transform:scale(1)}50%{opacity:1;transform:scale(1.5)}}

    /* Content layer */
    .scroll-wrap{position:relative;z-index:10}
    .act{min-height:100dvh;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden}

    /* L7: Pill scene */
    #pill-canvas{position:absolute;inset:0;width:100%;height:100%;z-index:2;cursor:pointer}

    /* Hero logo — between the pills */
    .hero-logo{
      position:relative;z-index:3;
      width:200px;height:200px;
      margin-bottom:20px;
      opacity:0;
      animation:logoReveal 1.2s .3s cubic-bezier(.16,1,.3,1) forwards;
      filter:drop-shadow(0 0 40px rgba(239,68,68,.25)) drop-shadow(0 0 80px rgba(59,130,246,.15));
    }
    @keyframes logoReveal{
      0%{opacity:0;transform:scale(.4) translateY(20px)}
      100%{opacity:1;transform:scale(1) translateY(0)}
    }

    /* Glitch text */
    #act-choice{flex-direction:column}
    .pill-hint{position:relative;z-index:4;margin-top:16px;font-size:.7rem;font-weight:300;letter-spacing:.25em;text-transform:uppercase;color:rgba(255,255,255,0);animation:hintIn 1.5s 4s forwards}
    @keyframes hintIn{0%{color:rgba(255,255,255,0)}50%{color:rgba(255,255,255,.15)}100%{color:rgba(255,255,255,.1)}}
    .glitch-word{position:relative;z-index:3;font-size:clamp(5rem,14vw,12rem);font-weight:900;letter-spacing:-.05em;line-height:1;pointer-events:none;user-select:none;mix-blend-mode:difference}
    .glitch-word .ch{display:inline-block;opacity:0;animation:chIn .18s forwards;animation-delay:var(--d)}
    @keyframes chIn{0%{opacity:0;transform:translateY(60px) scaleY(1.8) skewX(30deg);filter:blur(12px)}50%{opacity:1;transform:translateY(-8px) scaleY(.95) skewX(-4deg);filter:blur(0)}100%{opacity:1;transform:none}}

    /* Click flash */
    .pill-flash{position:fixed;inset:0;z-index:9990;pointer-events:none;opacity:0;transition:opacity .15s}
    .pill-flash.blue{background:radial-gradient(circle at center,rgba(59,130,246,.4),transparent 70%);opacity:1}
    .pill-flash.red{background:radial-gradient(circle at center,rgba(239,68,68,.4),transparent 70%);opacity:1}

    /* Scroll cue */
    .scroll-cue{position:absolute;bottom:36px;left:50%;transform:translateX(-50%);opacity:0;animation:fadeCue 1s 2.5s forwards;z-index:4}
    .pill-shape{width:28px;height:48px;border-radius:14px;border:1.5px solid rgba(255,255,255,.12);position:relative}
    .pill-shape::after{content:'';position:absolute;top:7px;left:50%;transform:translateX(-50%);width:4px;height:10px;border-radius:2px;background:rgba(255,255,255,.35);animation:cueDown 2s infinite}
    @keyframes cueDown{0%{opacity:1;transform:translateX(-50%) translateY(0)}100%{opacity:0;transform:translateX(-50%) translateY(18px)}}
    @keyframes fadeCue{to{opacity:1}}

    #act-shatter{min-height:60vh}

    /* L8: Scanlines */
    .scanlines{position:absolute;inset:0;pointer-events:none;z-index:3;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(59,130,246,.02) 2px,rgba(59,130,246,.02) 4px);animation:scanMove 10s linear infinite}
    @keyframes scanMove{to{transform:translateY(120px)}}

    /* Section captions — minimal narrative text */
    .caption{position:absolute;z-index:5;text-align:center;pointer-events:none;opacity:0;transition:opacity 1.2s .3s,transform 1.2s cubic-bezier(.16,1,.3,1)}
    .act.in .caption{opacity:1;transform:translateY(0)}
    .caption-top{top:12%;left:8vw;transform:translateY(-20px)}
    .act.in .caption-top{transform:translateY(0)}
    .caption-bottom{bottom:12%;left:50%;transform:translate(-50%,20px)}
    .act.in .caption-bottom{transform:translate(-50%,0)}
    .caption{text-align:left}
    .caption h2{font-size:clamp(1.4rem,3vw,2.2rem);font-weight:200;letter-spacing:.1em;line-height:1.4}
    .caption h2 strong{font-weight:700}
    .caption-blue h2{color:rgba(100,150,255,.5)}
    .caption-red h2{color:rgba(255,100,100,.5)}
    .caption-escape h2{color:rgba(200,50,50,.4);font-size:clamp(1rem,2vw,1.5rem)}
    .hero-sub{position:absolute;z-index:4;bottom:20%;left:50%;transform:translateX(-50%);font-size:clamp(.85rem,1.5vw,1.1rem);font-weight:300;color:rgba(255,255,255,.2);letter-spacing:.15em;text-align:center;white-space:nowrap;opacity:0;animation:fadeUp 1s 1.8s forwards}
    @keyframes fadeUp{from{opacity:0;transform:translate(-50%,15px)}to{opacity:1;transform:translate(-50%,0)}}

    /* Empire section — asymmetric layout */
    #act-empire{min-height:140dvh;flex-direction:column;gap:60px;padding:80px 20px;align-items:flex-start;padding-left:8vw}
    @media(max-width:768px){#act-empire{align-items:center;padding-left:20px}}
    .empire-hero{display:flex;flex-direction:column;align-items:flex-start;gap:24px;opacity:0;transition:all 1.2s cubic-bezier(.16,1,.3,1)}
    @media(max-width:768px){.empire-hero{align-items:center}}
    #act-empire.in .empire-hero{opacity:1}
    .empire-logo{width:80px;height:80px}
    .empire-title{font-size:clamp(2rem,5vw,4rem);font-weight:900;letter-spacing:-.02em;text-align:left;line-height:1.1}
    @media(max-width:768px){.empire-title{text-align:center}}
    .empire-title em{font-style:normal;background:linear-gradient(135deg,var(--red),var(--orange),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}

    /* 4 channels — big, prominent */
    .channels{display:grid;grid-template-columns:1.3fr 1fr 1fr 1.3fr;gap:0;max-width:1100px;width:90vw;opacity:0;transition:opacity 1.2s .5s}
    #act-empire.in .channels{opacity:1}
    @media(max-width:768px){.channels{grid-template-columns:repeat(2,1fr)}}
    .channel{display:flex;flex-direction:column;align-items:center;gap:16px;padding:40px 20px;position:relative;overflow:hidden;transition:transform .5s cubic-bezier(.16,1,.3,1)}
    .channel:nth-child(1){transform:translateY(0)}
    .channel:nth-child(2){transform:translateY(30px)}
    .channel:nth-child(3){transform:translateY(-10px)}
    .channel:nth-child(4){transform:translateY(20px)}
    .channel::before{content:'';position:absolute;inset:0;border:1px solid rgba(255,255,255,.04);border-radius:999px;opacity:0;transition:opacity .5s}
    .channel:hover::before{opacity:1}
    .channel-circle{width:96px;height:96px;border-radius:50%;display:flex;align-items:center;justify-content:center;border:2px solid rgba(255,255,255,.2);background:rgba(255,255,255,.06);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);transition:all .4s;color:rgba(255,255,255,.85);box-shadow:0 0 30px rgba(239,68,68,.08)}
    .channel:hover .channel-circle{border-color:rgba(239,68,68,.5);background:rgba(239,68,68,.12);color:#fff;transform:scale(1.12);box-shadow:0 0 50px rgba(239,68,68,.2)}
    .channel-circle svg{width:36px;height:36px}
    .channel-name{font-size:.85rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.7);transition:color .4s}
    .channel:hover .channel-name{color:#fff}
    .channel-desc{font-size:.8rem;font-weight:300;color:rgba(255,255,255,.35);text-align:center;line-height:1.5;max-width:180px;transition:color .4s}
    .channel:hover .channel-desc{color:rgba(255,255,255,.6)}

    /* Pulse rings around empire hero */
    .empire-rings{position:absolute;top:0;left:50%;transform:translateX(-50%);width:200px;height:200px;pointer-events:none}
    .pulse-ring{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);border-radius:50%;border:1px solid rgba(239,68,68,.15);animation:ringPulse 4s ease-out infinite}
    .pr1{width:100px;height:100px}
    .pr2{width:100px;height:100px;animation-delay:1.3s;border-color:rgba(249,115,22,.15)}
    .pr3{width:100px;height:100px;animation-delay:2.6s;border-color:rgba(245,158,11,.15)}
    @keyframes ringPulse{0%{transform:translate(-50%,-50%) scale(1);opacity:.5}100%{transform:translate(-50%,-50%) scale(6);opacity:0}}

    /* L9: Mouse trail */
    #trail-canvas{position:fixed;inset:0;z-index:9995;pointer-events:none}

    /* L10: Screen shake */
    .shake{animation:screenShake .4s ease-out}
    @keyframes screenShake{0%{transform:translate(0)}15%{transform:translate(-8px,6px)}30%{transform:translate(6px,-8px)}45%{transform:translate(-4px,4px)}60%{transform:translate(4px,-2px)}75%{transform:translate(-2px,2px)}100%{transform:translate(0)}}

    /* L11: Film grain */
    .grain{position:fixed;inset:0;z-index:9997;pointer-events:none;opacity:.04;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");animation:grain .4s steps(8) infinite}
    @keyframes grain{0%{transform:translate(0)}25%{transform:translate(-4%,-8%)}50%{transform:translate(6%,4%)}75%{transform:translate(-2%,6%)}100%{transform:translate(3%,-3%)}}

    /* L12: Vignette */
    .vignette{position:fixed;inset:0;z-index:9998;pointer-events:none;background:radial-gradient(ellipse at center,transparent 35%,rgba(0,0,0,.75) 100%)}

    /* L13: Chromatic aberration */
    #chroma{position:fixed;inset:0;z-index:9996;pointer-events:none;opacity:0;transition:opacity .2s}

    /* Footer */
    .quiet-footer{position:relative;z-index:10;padding:60px 0 40px;text-align:center}
    .quiet-footer a{color:rgba(255,255,255,.06);text-decoration:none;font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;transition:color .4s}
    .quiet-footer a:hover{color:rgba(255,255,255,.25)}

    /* Nav */
    .f-nav{position:fixed;top:20px;right:20px;z-index:10010;display:flex;gap:14px;align-items:center}
    .f-nav a,.f-nav span{color:rgba(255,255,255,.1);text-decoration:none;font-size:.65rem;letter-spacing:.15em;text-transform:uppercase;cursor:pointer;transition:color .3s}
    .f-nav a:hover,.f-nav span:hover{color:rgba(255,255,255,.4)}
  </style>
</head>
<body>

  <!-- L13: Cursor -->
  <div id="cursor"></div>
  <div id="cur-dot"></div>


  <!-- L0: Mesh gradient -->
  <div class="mesh-bg">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
    <div class="blob blob-4"></div>
    <div class="blob blob-5"></div>
  </div>

  <!-- L1: Three.js particles -->
  <canvas id="three-bg"></canvas>

  <!-- L2: Matrix rain -->
  <canvas id="matrix-canvas"></canvas>

  <!-- L3: Aurora -->
  <canvas id="aurora-canvas"></canvas>

  <!-- L4: Floating rings -->
  <div class="rings-layer">
    <div class="float-ring fr1"></div>
    <div class="float-ring fr2"></div>
    <div class="float-ring fr3"></div>
    <div class="float-ring fr4"></div>
    <div class="float-ring fr5"></div>
    <div class="float-ring fr6"></div>
  </div>


  <!-- L6: Light leaks -->
  <div class="light-leaks">
    <div class="leak leak-1"></div>
    <div class="leak leak-2"></div>
    <div class="leak leak-3"></div>
  </div>

  <!-- L9: Mouse trail -->
  <canvas id="trail-canvas"></canvas>

  <!-- L11-13: Post-processing -->
  <div id="chroma"></div>
  <div class="grain"></div>
  <div class="vignette"></div>

  <!-- Click flash -->
  <div class="pill-flash" id="pill-flash"></div>

  <!-- Nav -->
  <nav class="f-nav">
    <span id="lang-toggle">中文</span>
    <a href="/framework">framework</a>
  </nav>

  <!-- CONTENT -->
  <div class="scroll-wrap" id="scroll-wrap">

    <!-- ACT 1: CHOOSE -->
    <section class="act" id="act-choice">
      <video class="vid-bg" autoplay muted loop playsinline src="/videos/redesign/empire-bg.mp4"></video>
      <canvas id="pill-canvas"></canvas>
      <img src="/mofa-logo.png" alt="MoFA" class="hero-logo" />
      <div class="glitch-word" id="glitch-el"></div>
      <div class="pill-hint" id="pill-hint" data-en="pick a side" data-zh="选一边">pick a side</div>
      <div class="scroll-cue"><div class="pill-shape"></div></div>
    </section>

    <!-- ACT 2: OPPRESSION -->
    <section class="act" id="act-blue">
      <video class="vid-bg" id="vid-blue" autoplay muted loop playsinline src="/videos/redesign/blue-dystopia.mp4"></video>
      <div class="scanlines"></div>
      <div class="caption caption-top caption-blue">
        <h2 data-en="Their algorithm. Their content. <strong>Their rules.</strong>" data-zh="他们的算法。他们的内容。<strong>他们的规则。</strong>">Their algorithm. Their content. <strong>Their rules.</strong></h2>
      </div>
      <div class="caption caption-bottom caption-escape">
        <h2 data-en="...or <strong>break free</strong>" data-zh="...或者，<strong>挣脱</strong>">...or <strong>break free</strong></h2>
      </div>
    </section>

    <!-- ACT 3: SHATTERING -->
    <section class="act" id="act-shatter">
      <video class="vid-bg" id="vid-shatter" autoplay muted loop playsinline src="/videos/redesign/shatter.mp4"></video>
    </section>

    <!-- ACT 4: LIBERATION -->
    <section class="act" id="act-red">
      <video class="vid-bg" id="vid-empire" autoplay muted loop playsinline src="/videos/redesign/empire.mp4"></video>
      <div class="caption caption-top caption-red">
        <h2 data-en="Your voice. Your audience. <strong>Your empire.</strong>" data-zh="你的声音。你的受众。<strong>你的帝国。</strong>">Your voice. Your audience. <strong>Your empire.</strong></h2>
      </div>
    </section>

    <!-- ACT 5: YOUR EMPIRE -->
    <section class="act" id="act-empire">
      <video class="vid-bg" id="vid-empire2" autoplay muted loop playsinline src="/videos/redesign/empire-bg.mp4"></video>
      <div class="empire-hero">
        <div style="position:relative">
          <div class="empire-rings">
            <div class="pulse-ring pr1"></div>
            <div class="pulse-ring pr2"></div>
            <div class="pulse-ring pr3"></div>
          </div>
          <img src="/mofa-logo.png" alt="MoFA" class="empire-logo" />
        </div>
        <div class="empire-title">
          <span data-en="Your Personal" data-zh="你的个人">Your Personal</span><br/>
          <em data-en="Media Empire" data-zh="媒体帝国">Media Empire</em>
        </div>
      </div>

      <div class="channels">
        <div class="channel">
          <div class="channel-circle">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 0 1-2.25 2.25M16.5 7.5V18a2.25 2.25 0 0 0 2.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 0 0 2.25 2.25h13.5M6 7.5h3v3H6V7.5Z"/></svg>
          </div>
          <span class="channel-name" data-en="News Agency" data-zh="私人新闻社">News Agency</span>
          <span class="channel-desc" data-en="56 sources. Deep research. Your daily briefing." data-zh="56 个信源。深度研究。你的每日简报。">56 sources. Deep research. Your daily briefing.</span>
        </div>
        <div class="channel">
