<script is:inline>
// ======== GLOBALS ========
let scrollP=0, mx=0, my=0;
const docH=()=>document.body.scrollHeight-innerHeight;
addEventListener('scroll',()=>{scrollP=scrollY/(docH()||1)},{passive:true});
addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY});

// ======== CURSOR ========
const cur=document.getElementById('cursor'),dot=document.getElementById('cur-dot');
let cx=0,cy=0;
!function lp(){cx+=(mx-cx)*.12;cy+=(my-cy)*.12;cur.style.left=cx+'px';cur.style.top=cy+'px';dot.style.left=mx+'px';dot.style.top=my+'px';requestAnimationFrame(lp)}();

// ======== L1: THREE.JS — 25k PARTICLES ========
!function(){
  const c=document.getElementById('three-bg');
  const r=new THREE.WebGLRenderer({canvas:c,antialias:false,alpha:true});
  r.setSize(innerWidth,innerHeight);r.setPixelRatio(Math.min(devicePixelRatio,2));
  const scene=new THREE.Scene(),cam=new THREE.PerspectiveCamera(75,innerWidth/innerHeight,.1,1000);
  cam.position.z=60;
  const N=25000,pos=new Float32Array(N*3),col=new Float32Array(N*3),vel=new Float32Array(N*3),sz=new Float32Array(N);
  for(let i=0;i<N;i++){const i3=i*3;pos[i3]=(Math.random()-.5)*240;pos[i3+1]=(Math.random()-.5)*240;pos[i3+2]=(Math.random()-.5)*240;vel[i3]=(Math.random()-.5)*.02;vel[i3+1]=(Math.random()-.5)*.02;vel[i3+2]=(Math.random()-.5)*.02;sz[i]=Math.random()*2.8+.3}
  const geo=new THREE.BufferGeometry();
  geo.setAttribute('position',new THREE.BufferAttribute(pos,3));
  geo.setAttribute('color',new THREE.BufferAttribute(col,3));
  geo.setAttribute('size',new THREE.BufferAttribute(sz,1));
  const vs=`attribute float size;varying vec3 vColor;void main(){vColor=color;vec4 mv=modelViewMatrix*vec4(position,1.);gl_PointSize=size*(240./-mv.z);gl_Position=projectionMatrix*mv;}`;
  const fs=`varying vec3 vColor;void main(){float d=length(gl_PointCoord-.5);if(d>.5)discard;float a=1.-smoothstep(.1,.5,d);gl_FragColor=vec4(vColor,a*.5);}`;
  const mat=new THREE.ShaderMaterial({vertexShader:vs,fragmentShader:fs,transparent:true,vertexColors:true,depthWrite:false,blending:THREE.AdditiveBlending});
  const pts=new THREE.Points(geo,mat);scene.add(pts);
  let tRX=0,tRY=0;
  addEventListener('mousemove',e=>{tRY=(e.clientX/innerWidth-.5)*.6;tRX=(e.clientY/innerHeight-.5)*.4});
  // Color palettes: blue-world → shatter → red-world
  const cBlue=[0,.27,.8],cCyan=[0,.4,.67],cPurple=[.2,0,.6];
  const cRed=[.8,0,0],cOrange=[.8,.27,0],cGold=[.8,.53,0],cMagenta=[.6,0,.2];
  !function anim(){
    requestAnimationFrame(anim);
    pts.rotation.y+=(tRY-pts.rotation.y)*.015;pts.rotation.x+=(tRX-pts.rotation.x)*.015;
    const p=geo.attributes.position.array,c=geo.attributes.color.array,t=scrollP;
    const shatter=Math.max(0,1-Math.abs(t-.42)*6);
    for(let i=0;i<N;i++){
      const i3=i*3,sm=1+shatter*10;
      p[i3]+=vel[i3]*sm;p[i3+1]+=vel[i3+1]*sm;p[i3+2]+=vel[i3+2]*sm;
      if(Math.abs(p[i3])>120)vel[i3]*=-1;if(Math.abs(p[i3+1])>120)vel[i3+1]*=-1;if(Math.abs(p[i3+2])>120)vel[i3+2]*=-1;
      const hash=(i*7919)%5/5;
      if(t<.3){
        const pal=hash<.33?cBlue:hash<.66?cCyan:cPurple;
        c[i3]=pal[0];c[i3+1]=pal[1];c[i3+2]=pal[2];
      }else if(t<.55){
        const f=(t-.3)/.25;c[i3]=.3+f*.7;c[i3+1]=.3+f*.6;c[i3+2]=.9*(1-f)+f*.9;
      }else{
        const pal=hash<.33?cRed:hash<.66?cOrange:hash<.85?cGold:cMagenta;
        c[i3]=pal[0];c[i3+1]=pal[1];c[i3+2]=pal[2];
      }
    }
    geo.attributes.position.needsUpdate=true;geo.attributes.color.needsUpdate=true;
    r.render(scene,cam);
  }();
  addEventListener('resize',()=>{cam.aspect=innerWidth/innerHeight;cam.updateProjectionMatrix();r.setSize(innerWidth,innerHeight)});
}();

// ======== L7: 3D PILLS WITH RAYCASTING ========
!function(){
  const c=document.getElementById('pill-canvas');
  const r=new THREE.WebGLRenderer({canvas:c,antialias:true,alpha:true});
  r.setSize(innerWidth,innerHeight);r.setPixelRatio(Math.min(devicePixelRatio,2));
  r.toneMapping=THREE.ACESFilmicToneMapping;r.toneMappingExposure=1.3;
  const scene=new THREE.Scene(),cam=new THREE.PerspectiveCamera(50,innerWidth/innerHeight,.1,100);
  cam.position.z=8;
  scene.add(new THREE.AmbientLight(0x404040,.6));
  const bL=new THREE.PointLight(0x0044cc,4,25);bL.position.set(-5,3,5);scene.add(bL);
  const rL=new THREE.PointLight(0xcc0000,4,25);rL.position.set(5,-2,5);scene.add(rL);
  const cL=new THREE.PointLight(0x7c3aed,2,20);cL.position.set(0,4,3);scene.add(cL);
  const gL=new THREE.PointLight(0xf59e0b,1.5,15);gL.position.set(0,-3,4);scene.add(gL);
  scene.add(new THREE.DirectionalLight(0xffffff,.5).translateZ(-5).translateY(5));

  function pill(color,emColor,px){
    const g=new THREE.Group();const rad=.5,bh=1.9;
    const mT=new THREE.MeshPhysicalMaterial({color,emissive:emColor,emissiveIntensity:.15,metalness:.1,roughness:.15,clearcoat:1,clearcoatRoughness:.03,transparent:true,opacity:.94});
    const mB=new THREE.MeshPhysicalMaterial({color:new THREE.Color(color).multiplyScalar(.6),emissive:emColor,emissiveIntensity:.1,metalness:.1,roughness:.2,clearcoat:.8,clearcoatRoughness:.06,transparent:true,opacity:.94});
    const body=new THREE.Mesh(new THREE.CylinderGeometry(rad,rad,bh,32,1,true),mT);
    const top=new THREE.Mesh(new THREE.SphereGeometry(rad,32,16,0,Math.PI*2,0,Math.PI/2),mT);top.position.y=bh/2;
    const bot=new THREE.Mesh(new THREE.SphereGeometry(rad,32,16,0,Math.PI*2,Math.PI/2,Math.PI/2),mB);bot.position.y=-bh/2;
    g.add(body,top,bot);g.position.x=px;g.rotation.set(.35,0,px>0?.22:-.22);
    g.userData.type=px<0?'blue':'red';
    return g;
  }
  const bPill=pill(0x0044cc,0x001a66,-2.4);
  const rPill=pill(0xcc0000,0x660000,2.4);
  scene.add(bPill,rPill);

  // Raycaster for click
  const raycaster=new THREE.Raycaster();
  const mouse=new THREE.Vector2();
  let hovered=null;

  function getIntersects(ex,ey){
    mouse.x=(ex/innerWidth)*2-1;mouse.y=-(ey/innerHeight)*2+1;
    raycaster.setFromCamera(mouse,cam);
    return raycaster.intersectObjects([...bPill.children,...rPill.children]);
  }

  c.addEventListener('mousemove',e=>{
    const hits=getIntersects(e.clientX,e.clientY);
    const newH=hits.length?hits[0].object.parent.userData.type:null;
    if(newH!==hovered){
      hovered=newH;
      document.getElementById('cursor').classList.toggle('hover',!!newH);
      c.style.cursor=newH?'pointer':'none';
    }
  });

  c.addEventListener('click',e=>{
    const hits=getIntersects(e.clientX,e.clientY);
    if(!hits.length)return;
    const type=hits[0].object.parent.userData.type;
    const clickedPill=type==='blue'?bPill:rPill;

    // Split-open animation: top half up, bottom half down, inner glow
    const topHalf=clickedPill.children[1]; // sphere top
    const botHalf=clickedPill.children[2]; // sphere bottom
    const body=clickedPill.children[0]; // cylinder
    const origTopY=topHalf.position.y, origBotY=botHalf.position.y;

    // Add inner glow light
    const innerGlow=new THREE.PointLight(type==='blue'?0x0044cc:0xcc0000,8,5);
    innerGlow.position.set(0,0,0);
    clickedPill.add(innerGlow);

    let splitT=0;
    function splitAnim(){
      splitT+=0.04;
      const ease=1-Math.pow(1-Math.min(splitT,1),3); // ease-out cubic
      topHalf.position.y=origTopY+ease*1.2;
      botHalf.position.y=origBotY-ease*1.2;
      body.scale.y=1-ease*.5;
      body.material.opacity=.94-ease*.6;
      innerGlow.intensity=8+ease*15;
      if(splitT<1.5)requestAnimationFrame(splitAnim);
      else{
        // Reset after scroll
        setTimeout(()=>{
          topHalf.position.y=origTopY;
          botHalf.position.y=origBotY;
          body.scale.y=1;
          body.material.opacity=.94;
          clickedPill.remove(innerGlow);
        },1500);
      }
    }
    splitAnim();

    const flash=document.getElementById('pill-flash');
    flash.className='pill-flash '+type;
    setTimeout(()=>flash.className='pill-flash',600);
    document.getElementById('scroll-wrap').classList.add('shake');
    setTimeout(()=>document.getElementById('scroll-wrap').classList.remove('shake'),400);
    const hint=document.getElementById('pill-hint');
    if(hint)hint.style.opacity='0';
    setTimeout(()=>{
      const target=type==='blue'?'#act-blue':'#act-red';
      document.querySelector(target).scrollIntoView({behavior:'smooth'});
    },400);
  });

  let pmx=0,pmy=0;
  addEventListener('mousemove',e=>{pmx=(e.clientX/innerWidth-.5)*2;pmy=(e.clientY/innerHeight-.5)*2});
  const clock=new THREE.Clock();
  !function anim(){
    requestAnimationFrame(anim);const t=clock.getElapsedTime();
    bPill.position.y=Math.sin(t*.7)*.35;bPill.rotation.y=t*.25;
    rPill.position.y=Math.sin(t*.7+1.8)*.4;rPill.rotation.y=-t*.3;
    bPill.position.x=-2.4+pmx*.35;rPill.position.x=2.4+pmx*.35;
    cam.position.y=pmy*-.4;cam.lookAt(0,0,0);
    bL.position.set(-5+Math.sin(t)*2,3+Math.cos(t*.6)*1.5,5);
    rL.position.set(5+Math.sin(t+2)*2,-2+Math.cos(t*.7)*1.5,5);
    cL.position.set(Math.sin(t*.4)*3,4+Math.cos(t*.3),3);
    gL.position.set(Math.cos(t*.5)*2,-3+Math.sin(t*.4),4);
    // Hover glow + idle breathing pulse + hover vibrate
    const breath=.12+Math.sin(t*1.5)*.06;
    const hoverScale=1+Math.sin(t*8)*.008; // subtle vibration
    bPill.children.forEach(m=>{if(m.material)m.material.emissiveIntensity=hovered==='blue'?.5:breath});
    rPill.children.forEach(m=>{if(m.material)m.material.emissiveIntensity=hovered==='red'?.5:breath});
    if(hovered==='blue'){bPill.scale.setScalar(hoverScale*1.06);bL.intensity=6+Math.sin(t*4)*2}else{bPill.scale.setScalar(1);bL.intensity=4}
    if(hovered==='red'){rPill.scale.setScalar(hoverScale*1.06);rL.intensity=6+Math.sin(t*4)*2}else{rPill.scale.setScalar(1);rL.intensity=4}
    r.render(scene,cam);
  }();
  addEventListener('resize',()=>{cam.aspect=innerWidth/innerHeight;cam.updateProjectionMatrix();r.setSize(innerWidth,innerHeight)});
}();

// ======== GLITCH TEXT — resolves then cycles through skills ========
!function(){
  const el=document.getElementById('glitch-el');
  const words=['MoFA','SLIDES','PODCAST','VIDEO','COMIC','NEWS','RESEARCH','PUBLISH'];
  const glyphs='!@#$%^&*=+<>?/|~01';
  const colors=['var(--red)','var(--blue)','var(--cyan)','var(--purple)','var(--gold)','var(--magenta)'];
  let wordIdx=0,resolved=false,resolveTimer=null;

  function setWord(word){
    el.innerHTML=[...word].map((c,i)=>`<span class="ch" style="--d:${.6+i*.1}s">${c}</span>`).join('');
  }

  function scrambleTo(targetWord,cb){
    resolved=false;
    const len=Math.max(el.children.length,targetWord.length);
    // pad el to target length
    setWord(targetWord.replace(/./g,()=>glyphs[Math.floor(Math.random()*glyphs.length)]));
    const chars=el.querySelectorAll('.ch');
    let done=0;
    chars.forEach((ch,i)=>{
      const delay=100+i*80+Math.random()*120;
      const flips=3+Math.floor(Math.random()*4);
      let count=0;
      const iv=setInterval(()=>{
        if(count<flips){
          ch.textContent=glyphs[Math.floor(Math.random()*glyphs.length)];
          ch.style.color=colors[Math.floor(Math.random()*colors.length)];
          ch.style.textShadow='0 0 25px currentColor';
          count++;
        }else{
          clearInterval(iv);
          ch.textContent=targetWord[i]||'';
          ch.style.color='';
          ch.style.textShadow='';
          done++;
          if(done===chars.length){resolved=true;if(cb)cb();}
        }
      },80);
      setTimeout(()=>{},delay);
    });
  }

  // Initial: scramble to "MoFA"
  setWord('     ');
  setTimeout(()=>scrambleTo('MoFA',()=>{
    // After resolving, cycle through skills every 3s
    setInterval(()=>{
      wordIdx=(wordIdx+1)%words.length;
      scrambleTo(words[wordIdx]);
    },3000);
  }),800);

  // Occasional micro-glitch on resolved text
  setInterval(()=>{
    if(!resolved)return;
    const chars=el.querySelectorAll('.ch');
    if(!chars.length)return;
    const idx=Math.floor(Math.random()*chars.length),ch=chars[idx],orig=ch.textContent;
    ch.textContent=glyphs[Math.floor(Math.random()*glyphs.length)];
    ch.style.color=colors[Math.floor(Math.random()*colors.length)];
    ch.style.textShadow='0 0 25px currentColor';
    setTimeout(()=>{ch.textContent=orig;ch.style.color='';ch.style.textShadow=''},100);
  },400);
}();

// ======== L2: MATRIX RAIN ========
!function(){
  const c=document.getElementById('matrix-canvas'),ctx=c.getContext('2d');
  let W,H,cols,drops;
  function init(){W=c.width=innerWidth;H=c.height=innerHeight;cols=Math.floor(W/14);drops=Array(cols).fill(1)}
  init();addEventListener('resize',init);
  const chars='アイウエオカキクケコサシスセソタチツテトMOFA10'.split('');
  !function draw(){
    requestAnimationFrame(draw);
    ctx.fillStyle='rgba(0,0,0,.06)';ctx.fillRect(0,0,W,H);
    ctx.font='12px "Share Tech Mono",monospace';
    for(let i=0;i<cols;i++){
      const ch=chars[Math.floor(Math.random()*chars.length)];
      const hue=scrollP<.4?200:scrollP<.6?280:20;
      ctx.fillStyle=`hsla(${hue},80%,60%,.8)`;
      ctx.fillText(ch,i*14,drops[i]*14);
      if(drops[i]*14>H&&Math.random()>.975)drops[i]=0;
      drops[i]++;
    }
  }();
}();

// ======== L3: AURORA ========
!function(){
  const c=document.getElementById('aurora-canvas'),ctx=c.getContext('2d');
  const dpr=devicePixelRatio;
  function rs(){c.width=innerWidth*dpr;c.height=innerHeight*dpr;ctx.setTransform(dpr,0,0,dpr,0,0)}
  rs();addEventListener('resize',rs);
  !function draw(time){
    requestAnimationFrame(draw);
    const W=innerWidth,H=innerHeight;
    ctx.clearRect(0,0,W,H);
    const bands=[
      {color:'rgba(59,130,246,.3)',y:.25,amp:60,freq:.002,speed:.0003},
      {color:'rgba(6,182,212,.25)',y:.3,amp:50,freq:.003,speed:.0004},
      {color:'rgba(124,58,237,.2)',y:.35,amp:70,freq:.0015,speed:.00025},
      {color:'rgba(236,72,153,.15)',y:.4,amp:40,freq:.004,speed:.00035},
      {color:'rgba(239,68,68,.2)',y:.45,amp:55,freq:.0025,speed:.00045},
    ];
    for(const b of bands){
      ctx.beginPath();
      for(let x=0;x<=W;x+=3){
        const y=H*b.y+Math.sin(x*b.freq+time*b.speed)*b.amp+Math.sin(x*b.freq*2.3+time*b.speed*1.7)*b.amp*.5;
        x===0?ctx.moveTo(x,y):ctx.lineTo(x,y);
      }
      ctx.lineTo(W,H);ctx.lineTo(0,H);ctx.closePath();
      ctx.fillStyle=b.color;ctx.fill();
    }
  }(0);
}();



// ======== MOUSE TRAIL ========
!function(){
  const c=document.getElementById('trail-canvas'),ctx=c.getContext('2d');
  function rs(){c.width=innerWidth;c.height=innerHeight;c.style.width=innerWidth+'px';c.style.height=innerHeight+'px'}
  rs();addEventListener('resize',rs);
  const P=[];
  addEventListener('mousemove',e=>{
    for(let i=0;i<4;i++){
      const hues=scrollP<.35?[200,190,270]:scrollP<.55?[280,320,0]:[0,30,45,330];
      P.push({x:e.clientX,y:e.clientY,vx:(Math.random()-.5)*4,vy:(Math.random()-.5)*4,life:1,s:Math.random()*2.5+.5,h:hues[Math.floor(Math.random()*hues.length)]});
    }
  });
  !function draw(){
    requestAnimationFrame(draw);ctx.clearRect(0,0,innerWidth,innerHeight);
    for(let i=P.length-1;i>=0;i--){const p=P[i];p.x+=p.vx;p.y+=p.vy;p.life-=.02;if(p.life<=0){P.splice(i,1);continue}ctx.beginPath();ctx.arc(p.x,p.y,p.s*p.life,0,Math.PI*2);ctx.fillStyle=`hsla(${p.h},80%,60%,${p.life*.4})`;ctx.fill()}
    while(P.length>400)P.shift();
  }();
}();

// ======== CHROMATIC ABERRATION ========
addEventListener('scroll',()=>{
  const el=document.getElementById('chroma'),i=Math.max(0,1-Math.abs(scrollP-.42)*8);
  el.style.opacity=i*.2;
  if(i>0)el.style.boxShadow=`inset ${i*12}px 0 ${i*30}px rgba(239,68,68,.4),inset ${-i*12}px 0 ${i*30}px rgba(59,130,246,.4)`;
},{passive:true});

// ======== ORGANIC: Scroll-linked blob color shift ========
!function(){
  const blobs=document.querySelectorAll('.blob');
  const palettes=[
    ['#3b82f6','#7c3aed','#06b6d4','#ec4899','#14b8a6'],
    ['#ef4444','#f97316','#f59e0b','#ec4899','#7c3aed'],
  ];
  addEventListener('scroll',()=>{
    const t=scrollP;
    blobs.forEach((b,i)=>{
      const c0=palettes[0][i],c1=palettes[1][i];
      b.style.background=t<.5?c0:c1;
      b.style.opacity=.08+Math.sin(t*Math.PI+i)*.06;
    });
  },{passive:true});
}();

// ======== ORGANIC: Rings follow mouse gently ========
!function(){
  const rings=document.querySelectorAll('.float-ring');
  let rmx=0,rmy=0;
  addEventListener('mousemove',e=>{rmx=(e.clientX/innerWidth-.5)*30;rmy=(e.clientY/innerHeight-.5)*20});
  !function tick(){
    requestAnimationFrame(tick);
    rings.forEach((r,i)=>{
      const depth=(i+1)/rings.length;
      r.style.marginLeft=rmx*depth+'px';
      r.style.marginTop=rmy*depth+'px';
    });
  }();
}();

// ======== SCROLL REVEALS ========
const obs=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('in')})},{threshold:.2});
document.querySelectorAll('#act-blue,#act-red,#act-empire').forEach(el=>obs.observe(el));
// Shatter section reveal
const shObs=new IntersectionObserver(entries=>{entries.forEach(e=>{e.target.classList.toggle('in-view',e.isIntersecting)})},{threshold:.1});
shObs.observe(document.getElementById('act-shatter'));
// Pause offscreen videos for perf
const vidObs=new IntersectionObserver(entries=>{entries.forEach(e=>{const v=e.target.querySelector('video');if(v){if(e.isIntersecting)v.play().catch(()=>{});else v.pause()}})},{threshold:0});
document.querySelectorAll('.act').forEach(el=>vidObs.observe(el));

// ======== LANGUAGE ========
let lang='en';const lb=document.getElementById('lang-toggle');
function setL(l){lang=l;lb.textContent=l==='en'?'中文':'EN';document.querySelectorAll('[data-en][data-zh]').forEach(el=>{el.innerHTML=el.getAttribute('data-'+l)});localStorage.setItem('mofa-language',l)}
lb.addEventListener('click',()=>setL(lang==='en'?'zh':'en'));
if(localStorage.getItem('mofa-language')==='zh')setL('zh');
</script>

